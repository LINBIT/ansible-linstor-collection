# {{ ansible_managed }}
{% set _resource = _target._rd_name %}
{% set _ips = _target.service_ips %}
{% set _port = _target.target_port | default(ha_gateway_iscsi_port) | string %}
{% set _iqn = _target.iqn | default(ha_gateway_iscsi_iqn_base ~ ':' ~ _target.name) %}
{% set _fstype = _target.fstype | default(ha_gateway_fstype) %}
{% set _implementation = _target.implementation | default('') %}
{% set _allowed_initiators = _target.allowed_initiators | default([]) | join(' ') %}
{% set _username = _target.username | default('') %}
{% set _password = _target.password | default('') %}
{% set _volumes = _target.volumes %}
{% set _portals = _ips | map('regex_replace', '/.*', '') | map('regex_replace', '$', ':' ~ _port) | join(' ') %}
[[promoter]]

  [promoter.metadata]
    linstor-gateway-schema-version = 1

  [promoter.resources]

    [promoter.resources.{{ _resource }}]
      on-drbd-demote-failure = "reboot-immediate"
      on-disk-detach = "fail-over"
      adjust-resource-on-start = false
      runner = "systemd"
      stop-services-on-exit = true
      target-as = "Requires"
      start = [
        "ocf:heartbeat:Filesystem fs_cluster_private device=/dev/drbd/by-res/{{ _resource }}/0 directory=/srv/ha/internal/{{ _resource }} fstype={{ _fstype }} run_fsck=no",
{% for ip_cidr in _ips %}
{% set _ip = ip_cidr.split('/')[0] %}
{% set _mask = ip_cidr.split('/')[1] %}
        "ocf:heartbeat:portblock pblock{{ loop.index0 }} action=block ip={{ _ip }} portno={{ _port }} protocol=tcp",
        "ocf:heartbeat:IPaddr2 service_ip{{ loop.index0 }} cidr_netmask={{ _mask }} ip={{ _ip }}",
{% endfor %}
        "ocf:heartbeat:iSCSITarget target allowed_initiators='{{ _allowed_initiators }}' incoming_password={{ _password }} incoming_username={{ _username }} iqn={{ _iqn }} portals='{{ _portals }}'{{ ' implementation=' ~ _implementation if _implementation }}",
{% for vol in _volumes %}
{% set _lun = loop.index %}
{% set _serial = (_iqn ~ '-' ~ _lun | string) | hash('md5') %}
        "ocf:heartbeat:iSCSILogicalUnit lu{{ _lun }} lun={{ _lun }} path=/dev/drbd/by-res/{{ _resource }}/{{ _lun }} product_id={{ _serial[:8] }} scsi_sn={{ _serial[:8] }} target_iqn={{ _iqn }}{{ ' implementation=' ~ _implementation if _implementation }}",
{% endfor %}
{% for ip_cidr in _ips %}
{% set _ip = ip_cidr.split('/')[0] %}
        "ocf:heartbeat:portblock punblock{{ loop.index0 }} action=unblock ip={{ _ip }} portno={{ _port }} protocol=tcp tickle_dir=/srv/ha/internal/{{ _resource }}",
{% endfor %}
      ]
