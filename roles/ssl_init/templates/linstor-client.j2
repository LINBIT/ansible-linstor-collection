{# Controller address fallback: linstor_ip → replication_ip → ansible_host → localhost #}
[global]
controllers={% for address in linstor_controller_addresses %}linstors://{{ address }}{% if not loop.last %},{% endif %}{% endfor %}
{% if ssl_init_https_mtls | default(false) | bool %}

certfile={{ ssl_init_dir }}/client.pem
keyfile={{ ssl_init_dir }}/client.key
{% endif %}
